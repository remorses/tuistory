{
  "name": "tuistory",
  "version": "0.2.1",
  "description": "Playwright-like testing for TUI applications",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tuistory": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./pty": {
      "types": "./dist/pty-node.d.ts",
      "bun": "./dist/pty-bun.js",
      "default": "./dist/pty-node.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "test": "pnpm test:node && pnpm test:bun",
    "test:bun": "bun test",
    "test:node": "vitest --run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["tui", "terminal", "testing", "playwright", "e2e"],
  "author": "remorses",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/remorses/tuistory"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@hono/node-server": "^1.19.9",
    "@hono/node-ws": "^1.3.0",
    "@opentui/core": "0.1.88",
    "@opentui/react": "0.1.88",
    "errore": "^0.11.0",
    "ghostty-opentui": "workspace:^",
    "goke": "^6.6.0",
    "hono": "^4.11.7",
    "kill-port-process": "^3.2.1",
    "picocolors": "^1.1.1",
    "react": "^19",
    "std-env": "^4.1.0",
    "string-dedent": "^3.0.1",
    "zod": "4.3.6"
  },
  "optionalDependencies": {
    "zigpty": "^0.0.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/node": "^25.2.3",
    "bun-types": "^1.3.9",
    "typescript": "^5.9.2",
    "vitest": "^4.0.16"
  }
}
